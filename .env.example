VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the "publishable" key (formerly "anon") — safe to expose in browser code.
# Never use the "secret" key here; it bypasses RLS.
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Only for the dev/owner smoke-test seed (`npm run seed:food-design`). NOT used
# by the app. The script signs in with the publishable key as the list owner, so
# RLS still applies (no service-role/secret key is involved). Falls back to
# TEST_USER_EMAIL / TEST_USER_PASSWORD if these are unset.
SEED_USER_EMAIL=you@example.com
SEED_USER_PASSWORD=your-account-password
