save-exact=true

# Do not resolve versions published in the last seven days. Existing lockfile
# entries remain installable; this gate applies when npm resolves an update.
min-release-age=7

# Transitive packages must come from the npm registry, not a git repository.
# Root allows an explicitly reviewed direct git dependency if one is ever
# needed; CI separately rejects non-registry entries in package-lock.json.
allow-git=root

# Default-deny dependency lifecycle scripts. Supply-chain attacks like
# Mini Shai-Hulud execute through install hooks before app code ever runs.
# Use an explicit one-off override only after reviewing the dependency.
ignore-scripts=true
